# ============================================================
#  .env.example — SAFE TO COMMIT (no real values here)
#  Copy this to .env and fill in real values
#  .env is git-ignored and never committed
# ============================================================

# Secret key used to decrypt DB credentials in database.conf.php
# Must be at least 32 characters, random string
APP_SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_KEY_MIN_32_CHARS

# MySQL / MariaDB (used in docker-compose)
MYSQL_ROOT_PASSWORD=REPLACE_WITH_DB_ROOT_PASSWORD
MYSQL_DATABASE=testdb
